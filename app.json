{
  "expo": {
    "name": "Cidade Inteligente",
    "slug": "cidade-inteligente",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "cidade-inteligente",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "platforms": [
      "ios",
      "android"
    ],
    "android": {
      "package": "com.sorriso.cidadeinteligente",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1e40af"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.sorriso.cidadeinteligente",
      "supportsTablet": false
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Permitir acesso à localização para capturar coordenadas GPS do problema reportado."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Permitir acesso às fotos para anexar imagens à solicitação.",
          "cameraPermission": "Permitir acesso à câmera para tirar fotos do problema reportado."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "54c22bcc-8199-4163-82f7-5fbafa5b47d9"
      }
    }
  }
}
